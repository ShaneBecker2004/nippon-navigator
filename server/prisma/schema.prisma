generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Destination {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  tours      String
  image      String?
  location   String
  activities Activity[]
}

model Activity {
  id            Int             @id @default(autoincrement())
  category      String[]
  description   String?
  destinationId Int?
  duration      String?
  highlights    String[]
  location      String
  rating        Float?
  title         String
  details       Json?
  images        Json?
  phone         String?
  slug          String          @unique
  thumbnail     String?
  website       String?
  price         Json?
  currency      String?
  open_hours    String?
  type          String[]
  map_embed_url String?
  destination   Destination?    @relation(fields: [destinationId], references: [id])
  savedItems    SavedActivity[]
}

model Trip {
  id         String          @id @default(cuid())
  userId     String
  createdAt  DateTime        @default(now())
  endDate    DateTime?
  startDate  DateTime?
  description String?
  tripName   String

  savedItems SavedActivity[] @relation()
}

model SavedActivity {
  id         Int      @id @default(autoincrement())

  tripId     String   

  activityId Int
  notes      String?

  activity   Activity @relation(fields: [activityId], references: [id])
  trip       Trip     @relation(fields: [tripId], references: [id])
}
