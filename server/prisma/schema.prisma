generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Destination {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  slug      String     @unique
  image      String?
  location   String
  activities Activity[]
}

model Activity {
  id            Int             @id @default(autoincrement())
  category      String[]
  description   String?
  destinationId Int?
  duration      String?
  highlights    String[]
  location      String
  rating        Float?
  reviews       Int?
  title         String
  details       Json?
  images        Json?
  phone         String?
  slug          String          @unique
  thumbnail     String?
  website       String?
  price         Json?
  currency      String?
  open_hours    String?
  tags          String[]
  map_embed_url String?
  environment  String?
  accessibility String[]
  seasonal  String[]
  traveler  String[]
  popular   Boolean @default(false)
  top_rated Boolean @default(false)
  must_do Boolean @default(false)
  hidden Boolean @default(false)
  local Boolean @default(false)
  subcity   String?

  destination   Destination?    @relation(fields: [destinationId], references: [id])
  savedItems    SavedActivity[]

  @@index([destinationId])
}

model Trip {
  id          String   @id @default(cuid())
  userId      String

  tripName    String
  description String?

  startDate   DateTime?
  endDate     DateTime?

  arrivalLocation   String?
  departureLocation String?

  partySize  Int?

  notes      String?

  dayLabels Json?

  createdAt  DateTime @default(now())

  savedItems SavedActivity[]
}

model SavedActivity {
  id         Int      @id @default(autoincrement())

  tripId     String   

  activityId Int
  notes      String?

  order     Int @default(0)
  day         Int @default(1)
  time String?
  status String? // planned, booked, completed

  activity   Activity @relation(fields: [activityId], references: [id])
  trip       Trip     @relation(fields: [tripId], references: [id])
}
